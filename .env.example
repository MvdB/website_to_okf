# website-to-okf configuration (copy to .env and edit).
#
# Every setting can be given as a CLI flag, an environment variable, or a line
# in a local .env file. Env vars use the W2OKF_ prefix, except the OpenAI-style
# ones, which also accept the conventional OPENAI_* names. CLI flags win over
# env/.env, which win over the built-in defaults. .env is git-ignored.

# --- Target & output ---
W2OKF_SITE=https://example.com
W2OKF_OUTPUT_DIR=./bundle
# Ignore the discover/fetch buffers and re-crawl (distill cache still reused).
W2OKF_FRESH=false

# --- Discovery / crawl ---
W2OKF_MAX_PAGES=500
W2OKF_MAX_DEPTH=6
# auto | always | never  (auto = crawl-expand only when no sitemap is found)
W2OKF_FOLLOW_LINKS=auto
W2OKF_STRIP_QUERY=true

# --- Fetching ---
# crawl4ai (browser + fit_markdown) | trafilatura (lightweight static-first)
W2OKF_ENGINE=crawl4ai
W2OKF_PRUNE_THRESHOLD=0.48
W2OKF_CONCURRENCY=8
W2OKF_REQUEST_DELAY=0.2
W2OKF_TIMEOUT=30
W2OKF_RESPECT_ROBOTS=true

# --- Distillation (LLM, OpenAI-compatible endpoint) ---
W2OKF_USE_LLM=true
# Local server example: http://localhost:11434/v1 (Ollama), http://HOST:8000/v1 (vLLM)
OPENAI_BASE_URL=http://localhost:11434/v1
# Leave blank / "not-needed" for local servers that don't check keys.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Match this to your server's parallel-sequence capacity (e.g. vLLM --max-num-seqs).
W2OKF_LLM_CONCURRENCY=4
W2OKF_MAX_CHUNK_CHARS=12000

# --- OKF output ---
W2OKF_CONCEPT_TYPE=Web Page
W2OKF_BUNDLE_TITLE=
W2OKF_ADD_CITATIONS=true
W2OKF_WRITE_VIZ=true
